rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isYonseiEmail(email) {
      return email != null && email.matches('^.+@yonsei\\.ac\\.kr$');
    }

    // -----------------------------------------------------------------------
    // Email-link token exchange (앱 -> Firestore token 저장, Web -> token 조회)
    // -----------------------------------------------------------------------
    match /emailLinkTokens/{token} {
      // 앱(로그인 전)이 토큰 문서를 생성해야 하므로 create는 공개 허용 (UUID 기반)
      // hasOnly 제거: serverTimestamp 등으로 keys 검사가 실패할 수 있음
      allow create: if request.resource.data.email is string &&
          request.resource.data.kakaoUserId is string &&
          isYonseiEmail(request.resource.data.email) &&
          request.resource.data.keys().hasAll(['email', 'kakaoUserId', 'createdAt', 'expiresAt']);

      // Web 페이지가 토큰을 읽어 email/kakaoUserId를 알아내야 함
      // - 토큰이 없을 때도 "permission-denied"로 떨어지지 않게 get은 허용
      //   (존재 여부는 앱/웹에서 tokenSnap.exists로 판단)
      allow get: if true;

      // 나머지는 차단
      allow list: if false;
      allow update: if false;

      // Web에서 이메일 링크 로그인 완료 후 토큰 재사용 방지 삭제 (로그인 후에만)
      allow delete: if request.auth != null;
    }

    // -----------------------------------------------------------------------
    // Student verification writeback (Web or Flutter Web after email link sign-in)
    // -----------------------------------------------------------------------
    match /users/{kakaoUserId} {
      // 앱에서 인증 상태 확인/존재 확인에 사용 (필요 최소 get만 허용)
      // list: modelRecs 비어있을 때 폴백 피드용 (limit 적용은 쿼리에서)
      allow get: if true;
      allow list: if true;

      // 이메일 링크 로그인(FirebaseAuth) 후에만 학생 인증 필드 기록 허용
      allow create: if request.auth != null &&
          isYonseiEmail(request.auth.token.email) &&
          request.resource.data.keys().hasOnly([
            'kakaoUserId',
            'isStudentVerified',
            'studentEmail',
            'studentVerifiedAt',
            'verifiedAt'
          ]) &&
          (request.resource.data.kakaoUserId == null ||
            request.resource.data.kakaoUserId == kakaoUserId) &&
          request.resource.data.studentEmail is string &&
          isYonseiEmail(request.resource.data.studentEmail) &&
          request.resource.data.isStudentVerified == true;

      allow update: if (
            // (A) 이메일 링크 로그인(FirebaseAuth) 후 학생 인증 업데이트
            request.auth != null &&
          isYonseiEmail(request.auth.token.email) &&
          request.resource.data.studentEmail is string &&
          isYonseiEmail(request.resource.data.studentEmail) &&
          request.resource.data.isStudentVerified == true &&
          // 변경되는 키를 인증 관련 필드로 제한 (merge/set 모두 고려)
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'kakaoUserId',
            'isStudentVerified',
            'studentEmail',
            'studentVerifiedAt',
            'verifiedAt'
          ])
          ) || (
            // (B) 학생 인증이 완료된 문서에 한해 온보딩 데이터 업로드 허용 (앱에서 사용)
            // 문서 ID가 kakaoUserId이므로 kakaoUserId 필드 없어도 허용
            resource.data.isStudentVerified == true &&
            request.resource.data.isStudentVerified == true &&
            (request.resource.data.kakaoUserId == null ||
              request.resource.data.kakaoUserId == kakaoUserId) &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'kakaoUserId',
              'onboarding',
              'onboardingUpdatedAt',
              'initialSetupComplete',
              'initialSetupCompletedAt',
              'onboardingCompletedAt',
              'idealType',
              'idealTypeUpdatedAt',
              'updatedAt'
            ])
          );
    }

    // -----------------------------------------------------------------------
    // Blocks and Reports (신고 및 차단)
    // -----------------------------------------------------------------------
    match /blocks/{viewerUid}/targets/{targetUid} {
      // 본인의 차단 목록에만 생성 허용
      allow create: if request.auth != null && request.auth.uid == viewerUid;
      allow read: if request.auth != null && request.auth.uid == viewerUid;
    }

    match /reports/{reportId} {
      // 누구나(인증된 경우) 신고 생성 허용.
      allow create: if request.auth != null;
    }

    // -----------------------------------------------------------------------
    // ai_profiles — AI 취향 학습용 프로필 메타데이터 (height 등)
    // 앱에서 읽기만 필요
    // -----------------------------------------------------------------------
    match /ai_profiles/{profileId} {
      allow read: if true;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // modelRecs — AI 추천 결과 (Python 스크립트가 저장, 앱이 읽음)
    // modelRecs/{uid}/daily/{dateKey}/sources/{algo}
    // -----------------------------------------------------------------------
    match /modelRecs/{userId}/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // recEvents — 추천 학습용 이벤트 (KNN/SVD 등)
    // recEvents/{userId}/events/{eventId} — userId는 kakaoUserId
    // 앱은 카카오 로그인만 사용하므로 Firebase Auth 없이 쓰기 허용.
    // payload의 userId가 경로 userId와 일치할 때만 허용.
    // -----------------------------------------------------------------------
    match /recEvents/{userId} {
      allow read: if true;
      allow write: if true;
    }

    match /recEvents/{userId}/events/{eventId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // 기본 차단 (명시된 것만 허용)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

