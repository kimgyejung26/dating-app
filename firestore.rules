rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isYonseiEmail(email) {
      return email != null && email.matches('^.+@yonsei\\.ac\\.kr$');
    }

    // -----------------------------------------------------------------------
    // Email-link token exchange (앱 -> Firestore token 저장, Web -> token 조회)
    // -----------------------------------------------------------------------
    match /emailLinkTokens/{token} {
      allow create: if request.resource.data.email is string &&
          request.resource.data.kakaoUserId is string &&
          isYonseiEmail(request.resource.data.email) &&
          request.resource.data.keys().hasAll([
            'email',
            'kakaoUserId',
            'createdAt',
            'expiresAt'
          ]);

      allow get: if true;
      allow list: if false;
      allow update: if false;
      allow delete: if request.auth != null;
    }

    // -----------------------------------------------------------------------
    // Users
    // -----------------------------------------------------------------------
    // users 문서에 kakaoUserId 필드가 없으면 규칙에서 null 로 평가됨 → 프로필 수정 허용
    function usersDocKakaoIdOk(data, docKakaoId) {
      return data.kakaoUserId == null || data.kakaoUserId == docKakaoId;
    }

    match /users/{kakaoUserId} {
      allow get: if true;
      allow list: if true;

      // 연세 메일 학생 인증으로 최초 생성
      allow create: if request.auth != null &&
          isYonseiEmail(request.auth.token.email) &&
          request.resource.data.keys().hasOnly([
            'kakaoUserId',
            'isStudentVerified',
            'studentEmail',
            'studentVerifiedAt',
            'verifiedAt'
          ]) &&
          (request.resource.data.kakaoUserId == null ||
            request.resource.data.kakaoUserId == kakaoUserId) &&
          request.resource.data.studentEmail is string &&
          isYonseiEmail(request.resource.data.studentEmail) &&
          request.resource.data.isStudentVerified == true;

      // 카카오 로그인 후 users/{kakaoUserId} 최초 생성 (Firebase Auth 없음)
      // saveOnboarding* 등은 문서 ID가 곧 kakaoUserId 이므로 필드 생략 가능
      allow create: if usersDocKakaoIdOk(request.resource.data, kakaoUserId) &&
          request.resource.data.keys().hasOnly([
            'kakaoUserId',
            'nickname',
            'profileImageUrl',
            'email',
            'createdAt',
            'lastLoginAt',
            'onboarding',
            'onboardingUpdatedAt',
            'initialSetupComplete',
            'initialSetupCompletedAt',
            'onboardingCompletedAt',
            'idealType',
            'idealTypeUpdatedAt',
            'updatedAt',
            'hasSeenTutorial',
            'isStudentVerified',
            'studentEmail',
            'studentVerifiedAt',
            'verifiedAt',
            'preferenceVector'
          ]);

      allow update: if (
            request.auth != null &&
            isYonseiEmail(request.auth.token.email) &&
            request.resource.data.studentEmail is string &&
            isYonseiEmail(request.resource.data.studentEmail) &&
            request.resource.data.isStudentVerified == true &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'kakaoUserId',
              'isStudentVerified',
              'studentEmail',
              'studentVerifiedAt',
              'verifiedAt'
            ])
          ) || (
            resource.data.isStudentVerified == true &&
            request.resource.data.isStudentVerified == true &&
            usersDocKakaoIdOk(request.resource.data, kakaoUserId) &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'kakaoUserId',
              'onboarding',
              'onboardingUpdatedAt',
              'initialSetupComplete',
              'initialSetupCompletedAt',
              'onboardingCompletedAt',
              'idealType',
              'idealTypeUpdatedAt',
              'updatedAt'
            ])
          ) || (
            // 프로필 수정(온보딩 데이터 갱신) — 기존 규칙 유지 + 온보딩 편집 허용
            (request.resource.data.kakaoUserId == null ||
              request.resource.data.kakaoUserId == kakaoUserId) &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'kakaoUserId',
              'onboarding',
              'onboardingUpdatedAt',
              'idealType',
              'idealTypeUpdatedAt',
              'updatedAt'
            ])
          );

      // ---------------------------------------------------------------------
      // Device tokens
      // ---------------------------------------------------------------------
      match /deviceTokens/{token} {
        allow get, list: if true;

        allow create, update: if
          request.resource.data.userId is string &&
          request.resource.data.userId == kakaoUserId &&
          request.resource.data.token is string &&
          request.resource.data.token == token;

        allow delete: if true;
      }

      // ---------------------------------------------------------------------
      // In-app notifications
      // users/{kakaoUserId}/notifications/{notificationId}
      // ---------------------------------------------------------------------
      match /notifications/{notificationId} {
        allow get, list: if true;

        allow create: if
          request.resource.data.type is string &&
          request.resource.data.title is string &&
          request.resource.data.body is string &&
          request.resource.data.isRead is bool;

        allow update: if
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'isRead',
            'readAt'
          ]);

        allow delete: if true;
      }
    }

    // -----------------------------------------------------------------------
    // RecEvents (추천 학습용 이벤트 로그: open, like, nope 등)
    // -----------------------------------------------------------------------
    match /recEvents/{userId} {
      allow read, write: if true;

      match /events/{eventId} {
        allow read, write: if true;
      }
    }

    // -----------------------------------------------------------------------
    // Chat
    // -----------------------------------------------------------------------
    match /chat_rooms/{roomId} {
      allow read, create, update: if true;
      allow delete: if false;

      match /messages/{messageId} {
        allow read, create: if true;

        allow update: if
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'readBy',
            'updatedAt'
          ]);

        allow delete: if false;
      }
    }

    // -----------------------------------------------------------------------
    // Bamboo Forest (Community)
    // -----------------------------------------------------------------------
    match /bamboo_posts/{postId} {
      allow get, list: if true;

      allow create: if
        request.resource.data.postId is string &&
        request.resource.data.authorId is string &&
        request.resource.data.authorId.size() > 0 &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.content.size() <= 500 &&
        request.resource.data.category is string &&
        request.resource.data.category.size() > 0 &&
        request.resource.data.tags is list &&
        request.resource.data.likeCount == 0 &&
        request.resource.data.commentCount == 0 &&
        request.resource.data.score7d == 0 &&
        request.resource.data.isDeleted == false;

      allow update: if
        (
          resource.data.authorId == request.resource.data.authorId &&
          request.resource.data.isDeleted == true
        )
        ||
        (
          request.resource.data.authorId == resource.data.authorId &&
          request.resource.data.content == resource.data.content &&
          request.resource.data.category == resource.data.category &&
          request.resource.data.tags == resource.data.tags
        );

      allow delete: if false;

      // ---------------------------------------------------------------------
      // Post likes
      // ---------------------------------------------------------------------
      match /likes/{userId} {
        allow get, list: if true;

        allow create: if
          request.resource.data.userId is string &&
          request.resource.data.userId == userId;

        allow delete: if true;
        allow update: if false;
      }

      // ---------------------------------------------------------------------
      // Comments / Replies
      // ---------------------------------------------------------------------
      match /comments/{commentId} {
        allow get, list: if true;

        allow create: if
          request.resource.data.commentId is string &&
          request.resource.data.authorId is string &&
          request.resource.data.authorId.size() > 0 &&
          request.resource.data.content is string &&
          request.resource.data.content.size() > 0 &&
          request.resource.data.content.size() <= 500 &&
          request.resource.data.likeCount == 0 &&
          request.resource.data.isDeleted == false;

        allow update: if
          (
            resource.data.authorId == request.resource.data.authorId &&
            request.resource.data.isDeleted == true
          )
          ||
          (
            request.resource.data.authorId == resource.data.authorId &&
            request.resource.data.content == resource.data.content &&
            request.resource.data.parentCommentId == resource.data.parentCommentId
          );

        allow delete: if false;

        // -------------------------------------------------------------------
        // Comment likes
        // -------------------------------------------------------------------
        match /likes/{userId} {
          allow get, list: if true;

          allow create: if
            request.resource.data.userId is string &&
            request.resource.data.userId == userId;

          allow delete: if true;
          allow update: if false;
        }
      }
    }

    // -----------------------------------------------------------------------
    // Blocks and Reports
    // -----------------------------------------------------------------------
    match /blocks/{viewerUid} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;

      match /targets/{targetUid} {
        allow read: if true;
        allow create, update: if
          request.resource.data.fromUserId is string &&
          request.resource.data.toUserId is string &&
          request.resource.data.fromUserId == viewerUid &&
          request.resource.data.toUserId == targetUid;
        allow delete: if true;
      }
    }

    match /reports/{reportId} {
      allow create: if
        request.resource.data.reporterId is string &&
        request.resource.data.reportedId is string &&
        request.resource.data.reason is string &&
        request.resource.data.reason.size() > 0 &&
        request.resource.data.status is string;
      allow read: if true;
      allow update: if true;
      allow delete: if true;
    }

    match /app_issue_reports/{reportId} {
      allow create: if
        request.resource.data.reporterId is string &&
        request.resource.data.category is string &&
        request.resource.data.category.size() > 0 &&
        request.resource.data.content is string &&
        request.resource.data.content.size() > 0 &&
        request.resource.data.allowContact is bool &&
        request.resource.data.sourceScreen is string &&
        request.resource.data.platform is string &&
        request.resource.data.status is string;

      allow read: if true;
      allow update: if true;
      allow delete: if true;
    }
    match /app_inquiries/{inquiryId} {
  allow create: if
    request.resource.data.inquirerId is string &&
    request.resource.data.category is string &&
    request.resource.data.category.size() > 0 &&
    request.resource.data.content is string &&
    request.resource.data.content.size() > 0 &&
    request.resource.data.allowContact is bool &&
    request.resource.data.sourceScreen is string &&
    request.resource.data.platform is string &&
    request.resource.data.status is string;

  allow read: if true;
  allow update: if true;
  allow delete: if true;
}

    // -----------------------------------------------------------------------
    // AI Profiles (더미 프로필 메타데이터: height 등, AI 취향 화면용)
    // -----------------------------------------------------------------------
    match /ai_profiles/{profileId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    // -----------------------------------------------------------------------
    // Model Recs (AI 추천 결과: rrf, clip, svd, knn — 서버에서 저장, 앱에서 읽기)
    // -----------------------------------------------------------------------
    match /modelRecs/{userId}/daily/{dateKey}/sources/{algo} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // AI Profiles (더미 프로필 메타데이터: height 등, AI 취향 화면용)
    // -----------------------------------------------------------------------
    match /ai_profiles/{profileId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    // -----------------------------------------------------------------------
    // Model Recs (AI 추천 결과: rrf, clip, svd, knn — 서버에서 저장, 앱에서 읽기)
    // Kakao 로그인 시 request.auth가 null일 수 있어 read는 허용
    // -----------------------------------------------------------------------
    match /modelRecs/{userId}/daily/{dateKey}/sources/{algo} {
      allow read: if true;
      allow write: if false;
    }

    // -----------------------------------------------------------------------
    // Asks (무물: 1:1 질문)
    // -----------------------------------------------------------------------
    match /asks/{askId} {
      allow read: if true;

      allow create: if
        request.resource.data.fromUserId is string &&
        request.resource.data.fromUserId.size() > 0 &&
        request.resource.data.toUserId is string &&
        request.resource.data.toUserId.size() > 0 &&
        request.resource.data.text is string &&
        request.resource.data.text.size() > 0 &&
        request.resource.data.status is string;

      allow update: if
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status', 'readAt', 'updatedAt'
        ]);

      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // Interactions (like / nope / view / message)
    // -----------------------------------------------------------------------
    match /interactions/{interactionId} {
      allow read: if true;
      allow create: if
        request.resource.data.fromUserId is string &&
        request.resource.data.fromUserId.size() > 0 &&
        request.resource.data.toUserId is string &&
        request.resource.data.toUserId.size() > 0 &&
        request.resource.data.action is string &&
        request.resource.data.source is string &&
        request.resource.data.keys().hasOnly([
          'fromUserId', 'toUserId', 'action', 'source',
          'metadata', 'createdAt'
        ]);
      allow update, delete: if false;
    }

    // -----------------------------------------------------------------------
    // Matches (매치 성사 기록)
    // -----------------------------------------------------------------------
    match /matches/{matchId} {
      allow read: if true;
      allow create: if
        request.resource.data.userIds is list &&
        request.resource.data.userIds.size() == 2 &&
        request.resource.data.matchType is string &&
        request.resource.data.status is string &&
        request.resource.data.keys().hasOnly([
          'userIds', 'matchType', 'matchedAt', 'status', 'chatRoomId'
        ]);
      allow update: if
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'status',
          'unmatchedAt',
          'chatRoomId'
        ]);
      allow delete: if false;
    }

    // -----------------------------------------------------------------------
    // Default deny
    // -----------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}